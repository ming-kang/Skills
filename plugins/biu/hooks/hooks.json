{
  "description": "Biu plugin hooks: subagent artifact verification + task-complete reminder (pure bash, zero runtime deps)",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(**/.biu/tasks/task-*.md)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/notify-task-complete.sh"
          },
          {
            "type": "command",
            "if": "Write(**/.biu/tasks/task-*.md)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/notify-task-complete.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "^biu:analyzer$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/verify-analyzer.sh"
          }
        ]
      },
      {
        "matcher": "^biu:architect$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/verify-architect.sh"
          }
        ]
      }
    ]
  }
}
