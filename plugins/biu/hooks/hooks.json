{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.md)",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/notify-task-complete.sh\""
          },
          {
            "type": "command",
            "if": "Write(*.md)",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/notify-task-complete.sh\""
          }
        ]
      }
    ]
  }
}
